flowchart TD
    S1["1. Acquire namespace apply lock"] --> S2["2. Re-read live snapshot digest"]
    S2 --> S3["3. Validate preconditions"]
    S3 -->|"snapshot mismatch"| E14["Release lock → EXIT 14"]
    S3 -->|"approval fail"| E12["Release lock → EXIT 12"]
    S3 -->|"trust/sig fail"| E13["Release lock → EXIT 13"]
    S3 -->|"pass"| S4["4. Start TXN"]
    S4 --> S5["5. Apply operations in order"]
    S5 -->|"unknown op"| ROLL_16["Rollback TXN → Release lock → EXIT 16"]
    S5 -->|"success"| S6["6. Validate postconditions\n(schema, DAG acyclicity, reachability)"]
    S6 -->|"ref integrity fail"| ROLL_10["Rollback TXN → Release lock → EXIT 10"]
    S6 -->|"DAG cycle / dangling ref"| ROLL_11["Rollback TXN → Release lock → EXIT 11"]
    S6 -->|"pass"| S7["7. Compute newSnapshotDigest"]
    S7 --> S8["8. Persist snapshot + ApplyReceipt"]
    S8 --> S9["9. Commit TXN"]
    S9 -->|"success"| S10["10. Release lock → EXIT 0"]
    S9 -->|"partial side-effect"| COMP["Apply rollbackOperations[]"]
    COMP -->|"compensation ok"| E17["Release lock → EXIT 17"]
    COMP -->|"compensation fail"| E18["Release lock → EXIT 18 (critical)"]

    S1 -->|"lock timeout"| E15["EXIT 15: lock timeout"]
