{
  "name": "xyph",
  "version": "1.0.0-alpha.15",
  "description": "Agent Planning and Orchestration framework powered by Causal Agents and WARP graphs.",
  "type": "module",
  "bin": {
    "xyph": "dist/xyph.js"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\" \"scripts/**/*.mts\" xyph.ts xyph-actuator.ts xyph-dashboard.ts xyph-theme-lab.ts",
    "build": "tsc",
    "coordinator": "node dist/src/coordinator-daemon.js",
    "verify:patch-ops": "npm run build && node scripts/verify-patch-ops.mjs patches",
    "test": "docker build -t xyph-test . && docker run --rm xyph-test npm run test:local",
    "test:local": "vitest run",
    "graph:pull": "git fetch origin 'refs/warp/xyph-roadmap/writers/*:refs/warp/xyph-roadmap/writers/*'",
    "graph:push": "git push origin 'refs/warp/xyph-roadmap/writers/*:refs/warp/xyph-roadmap/writers/*'",
    "graph:work": "npx tsx scripts/generate-work-dag.ts",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@flyingrobots/bijou": "^1.8.0",
    "@flyingrobots/bijou-node": "^1.8.0",
    "@flyingrobots/bijou-tui": "^1.8.0",
    "@git-stunts/git-warp": "^14.6.0",
    "@git-stunts/plumbing": "^2.8.0",
    "@git-stunts/vault": "^1.0.1",
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1",
    "ajv": "^8.18.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "overrides": {
    "flatted": "^3.4.1",
    "minimatch": "^10.2.1",
    "tar": "7.5.11"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.4.2",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  }
}
