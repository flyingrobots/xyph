#!/bin/sh
# pre-commit — lint gate
# Zero errors, zero warnings. A clean codebase stays clean.

npm run lint

# No inline mermaid blocks — use docs/diagrams/*.mmd + render-diagrams.sh
if grep -rn '```mermaid' README.md CONTRIBUTING.md docs/ --include='*.md' 2>/dev/null; then
  echo "Error: Found inline \`\`\`mermaid blocks. Extract to docs/diagrams/*.mmd and run scripts/render-diagrams.sh"
  exit 1
fi
